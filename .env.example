# Copy this file to .env and fill in your keys.
# DO NOT commit .env to source control.

# Anthropic API key — DEV/Expo Go only. Production scans go through the
# Supabase analyze-scan Edge Function; the key never ships in the app.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase project (Settings → API). Anon key is public by design.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# RevenueCat PUBLIC per-platform SDK keys (Project → API Keys).
# NEVER put the RevenueCat secret key, webhook secret, Apple shared
# secret, or Google service-account JSON anywhere in the app or repo.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your-public-ios-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your-public-android-key

# Legal links shown on the paywall / settings
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy

# Master kill switch for the monetization layer
EXPO_PUBLIC_MONETIZATION_ENABLED=false
