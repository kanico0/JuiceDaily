{
  "expo": {
    "name": "RawLifeFlow: Juicing Daily",
    "slug": "rawlifeflow-juicing-daily",
    "version": "1.0.2",
    "scheme": "juicingapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.juicingapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "useNextNotificationsApi": true
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/glass_clink.wav"
          ]
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "20be049d-1a88-4fe1-b72e-926d83ef6b2c"
      }
    },
    "owner": "kanico",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/20be049d-1a88-4fe1-b72e-926d83ef6b2c"
    }
  }
}
