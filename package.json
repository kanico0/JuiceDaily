{
  "name": "juicingapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:go": "cross-env EXPO_PUBLIC_BUILD_TARGET=go expo start --go",
    "start:go:tunnel": "cross-env EXPO_PUBLIC_BUILD_TARGET=go expo start --go --tunnel",
    "start:beta": "cross-env EXPO_PUBLIC_BUILD_TARGET=beta expo start --dev-client",
    "build:beta": "eas build -p android --profile beta",
    "build:beta:ios": "eas build -p ios --profile beta",
    "update:beta": "eas update --branch beta --message",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@supabase/supabase-js": "^2.110.5",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-modules-core": "^3.0.29",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "lucide-react-native": "^0.564.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dotenv": "^3.4.11",
    "react-native-purchases": "^10.4.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "babel-preset-expo": "^54.0.10",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^8.0.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
